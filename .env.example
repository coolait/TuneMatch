# Spotify — get from https://developer.spotify.com/dashboard
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here
# Client secret is NOT used on the frontend (PKCE flow) but kept here for reference
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Anthropic — get from https://console.anthropic.com
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Spotify redirect URI — must be registered in your Spotify app dashboard
# Add exactly: https://quick-onions-yawn.loca.lt
